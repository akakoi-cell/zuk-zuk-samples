# =========================================================
# みらい税理士事務所 (税理士サンプル #67) 環境変数テンプレート
# このファイルを .env.local にコピーして値を埋める。
# .env.local は .gitignore 済み (コミットしない)。
# =========================================================

# ---- サイト基本 ----
# 本番ドメイン (末尾スラッシュ無し)。未設定時は samples.zuk-zuk.com を使用。
NEXT_PUBLIC_SITE_URL=https://samples.zuk-zuk.com

# ---- Sanity CMS (Phase F / Works・Column) ----
# 未設定の間はハードコードデータ (tax-content.ts) にフォールバックする。
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# seed / 書き込み用 (NEXT_PUBLIC_ を付けない = サーバ専用)
SANITY_API_WRITE_TOKEN=

# ---- Web3Forms (Phase G / Contact フォーム) ----
# 未設定時はフォームを「準備中」表示にする。
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
# hCaptcha (テンプレ固定のテストキー)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=50b2fe65-b00b-4b9e-ad62-3ba471098be2

# ---- Slack 通知 (Phase K, オプション) ----
SLACK_WEBHOOK_URL=

# ---- Stripe 単発決済 (Phase J, オプション) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Google Analytics 4 (オプション) ----
NEXT_PUBLIC_GA4_ID=
