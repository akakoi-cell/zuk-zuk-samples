# =============================================
# zuk-zuk template — 環境変数テンプレート
# 本ファイルをコピーして .env.local を作成してください
#   cp .env.example .env.local
# =============================================

# --- サイト基本情報 ---
# 本番ドメイン (https:// 込み)。OGP・JSON-LD・sitemap で利用。
NEXT_PUBLIC_SITE_URL=https://example.com

# --- Adobe Fonts (Typekit) ---
# 未設定でも動作する (Google Fonts の Zen Kaku + Caveat にフォールバック)。
# zuk-zuk スタンダードフォントを使う場合: gux5cqf
# 案件固有の Typekit がある場合: その kit ID
# 取得方法: https://fonts.adobe.com/my_fonts#web_projects-section → Embed Code の kitId
NEXT_PUBLIC_TYPEKIT_KIT_ID=

# 以下、案件で必要な機能を追加する際の参考。
# 不要なら空のままで OK。

# --- Web3Forms (お問い合わせフォーム) ---
# Skill: setup-contact-form-web3forms 参照
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=50b2fe65-b00b-4b9e-ad62-3ba471098be2

# --- Sanity CMS ---
# Skill: setup-sanity-cms 参照
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# SANITY_API_WRITE_TOKEN=

# --- Slack 通知 ---
# Skill: setup-slack-notifications 参照
# SLACK_WEBHOOK_URL=
# SLACK_NOTIFY_USER_ID=

# --- Google Analytics 4 ---
# Skill: setup-google-analytics-search-console 参照
# NEXT_PUBLIC_GA4_ID=

# --- Stripe (サブスク決済が必要な案件のみ) ---
# Skill: setup-stripe-subscription 参照
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
